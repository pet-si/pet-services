import java.lang.Boolean;

CREATE TABLE IF NOT EXISTS user (
    idUser INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    email TEXT NOT NULL UNIQUE,
    companyName TEXT NOT NULL,
    password TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS report (
    idReport INTEGER PRIMARY KEY AUTOINCREMENT,
    filePath TEXT NOT NULL,
    date TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS settings (
    settingName TEXT NOT NULL UNIQUE,
    value INTEGER AS Boolean DEFAULT 1
);

CREATE TABLE IF NOT EXISTS sincronization (
    tableName TEXT NOT NULL UNIQUE,
    lastUpdate TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS expense (
    idExpense INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    amount REAL NOT NULL,
    date TEXT NOT NULL,
    category TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS client (
    idClient INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    cpf TEXT UNIQUE,
    email TEXT  UNIQUE,
    phoneNumber TEXT,
    points INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS purchaseOrder (
    idPurchaseOrder INTEGER PRIMARY KEY AUTOINCREMENT,
    idClient INTEGER NOT NULL,
    date TEXT NOT NULL,

    FOREIGN KEY (idClient) REFERENCES client(idClient)
);

CREATE TABLE IF NOT EXISTS product (
    idProduct INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    quantity INTEGER DEFAULT 0,
    costPrice REAL NOT NULL,
    salePrice REAL NOT NULL,
    minimunStock INTEGER DEFAULT 0,
    soldQuantity INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS purchaseOrder_Products (
    idPurchaseOrder INTEGER NOT NULL,
    idProduct INTEGER NOT NULL,
    quantity INTEGER DEFAULT 1,

    PRIMARY KEY (idPurchaseOrder, idProduct),
    FOREIGN KEY (idPurchaseOrder) REFERENCES purchaseOrder(idPurchaseOrder),
    FOREIGN KEY (idProduct) REFERENCES product(idProduct)
);

CREATE TABLE IF NOT EXISTS material (
    idMaterial INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    quantity INTEGER DEFAULT 0,
    costPrice REAL NOT NULL,
    minimunStock INTEGER DEFAULT 0,
    metric TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS product_materials (
    idProduct INTEGER NOT NULL,
    idMaterial INTEGER NOT NULL,
    quantity REAL NOT NULL,

    PRIMARY KEY (idProduct, idMaterial),
    FOREIGN KEY (idProduct) REFERENCES product(idProduct),
    FOREIGN KEY (idMaterial) REFERENCES material(idMaterial)
);